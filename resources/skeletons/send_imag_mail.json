        "jsCode": "// HTTP Request 노드에서 받은 이미지 바이너리 'data'의 알맹이를 가져옵니다.\nconst binaryProperty = items[0].binary.data;\n\n// 바이너리 데이터를 Base64 텍스트로 강제 변환합니다.\nconst base64String = await this.helpers.getBinaryDataBuffer(0, 'data').then(buffer => buffer.toString('base64'));\n\nreturn [{\n  json: {\n    // 이제 image_url에는 'filesystem-v2'가 아닌 'iVBORw0...' 같은 실제 데이터가 담깁니다.\n    image_url: base64String\n  }\n}];"
