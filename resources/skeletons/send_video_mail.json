    {
      "parameters": {
        "jsCode": "// 1. Merge 노드에서 합쳐진 비디오 배열과 오디오 배열 가져오기\nconst data = $input.first().json;\nconst videos = data.videos || [];\nconst audios = data.data.response.sunoData || [];\n\nlet result = [];\n\n// 혹시라도 영상이나 오디오가 비어있으면 에러 방지용으로 빈 배열 리턴\nif (videos.length === 0 || audios.length === 0) {\n  return result;\n}\n\n// 2. 단일(고정) 비디오 정보 미리 추출 (첫 번째 영상만 무조건 사용)\nconst singleVideo = videos[0];\nconst bestVideoLink = singleVideo.video_files.sort((a, b) => b.width - a.width)[0].link;\nconst videoDuration = singleVideo.duration;\n\n// 3. 오디오 개수만큼 루프 돌면서 아이템 찢기 (1:N 매칭)\nfor (let i = 0; i < audios.length; i++) {\n  result.push({\n    json: {\n      video_link: bestVideoLink, // 고정된 영상 링크\n      duration: videoDuration,   // 고정된 영상 길이\n      audio_link: audios[i].audioUrl // 오디오만 1, 2, 3번 순차적으로 변경\n    }\n  });\n}\n\n// 4. 쪼개진 아이템들을 리턴\nreturn result;"
      },
