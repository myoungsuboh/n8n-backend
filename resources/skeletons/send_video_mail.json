    {
      "parameters": {
        "jsCode": "for (let item of $input.all()) {\n  try {\n    // 1. AI가 뱉은 통짜 문자열 가져오기\n    let rawText = item.json.output;\n    \n    // 2. 마크다운 기호(```json, ```) 싹 다 지우고 양옆 공백 제거\n    let cleanText = rawText.replace(/```json/gi, '').replace(/```/gi, '').trim();\n    \n    // 3. 깨끗해진 텍스트를 진짜 JSON 객체로 변환\n    let parsedData = JSON.parse(cleanText);\n    \n    // 4. 변환된 값을 item.json에 쓰기 좋게 세팅\n    item.json.video_query = parsedData.video_query;\n    item.json.audio_prompt = parsedData.audio_prompt;\n    \n  } catch (error) {\n    // 혹시라도 AI가 이상한 말을 뱉어서 에러가 나면 확인하기 위함\n    item.json.error = \"파싱 에러: \" + error.message;\n  }\n}\n\nreturn $input.all();"
      },
