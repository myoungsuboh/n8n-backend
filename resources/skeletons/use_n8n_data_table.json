      "id": "b796f64d-cb66-4e53-beba-77ff70db7e03",
      "name": "embedding"
    },
    {
      "parameters": {
        "jsCode": "const pages = $input.first().json.pages || [];\n\nconst fileName = $('Upload your file here').first().json.data[0].filename || 'unknown';\n\nconst result = [];\n\nconst CHUNK_SIZE = 5; // 한 번에 5줄씩 묶음 (맥락 파악용)\nconst OVERLAP = 1;    // 다음 묶음이랑 1줄은 겹치게 함 (문맥 끊김 방지)\n\npages.forEach(page => {\n  const markdown = page.markdown;\n  \n  if (markdown && markdown.length > 0) {\n    // 1. 일단 줄바꿈으로 나누고, 빈 줄(공백)은 미리 제거합니다.\n    // 빈 줄 때문에 쓸데없이 청크가 낭비되는 것을 막습니다.\n    const lines = markdown.split('\\n').filter(line => line.trim().length > 0);\n\n    // 2. 슬라이딩 윈도우 로직 적용\n    // i를 (CHUNK_SIZE - OVERLAP) 만큼씩 점프하면서 반복\n    for (let i = 0; i < lines.length; i += (CHUNK_SIZE - OVERLAP)) {\n        \n        // i번째부터 5줄을 가져옴\n        const chunkLines = lines.slice(i, i + CHUNK_SIZE);\n        \n        // 내용이 없으면 중단\n        if (chunkLines.length === 0) break;\n\n        // 5줄을 다시 하나의 문자열로 합침 (\\n으로 연결)\n        const chunkContent = chunkLines.join('\\n');\n\n        // 데이터 저장 할 때 embedding 처리해서 String으로 넣어뒀음.\n        // 표 기호 제거 및 줄바꿈을 공백으로 하여 한 문장처럼 만듦\n        const cleanContent = chunkContent\n            .replace(/\\|/g, ' ')  // 표 기호 제거\n            .replace(/\\n/g, ' ')  // 줄바꿈을 공백으로 (한 문장처럼 만듦)\n            .replace(/\\s+/g, ' ') // 연속된 공백을 하나로 축소\n            .trim();\n\n        if(cleanContent.length < 1) continue\n      \n        result.push({\n            json: {\n                content: cleanContent,\n                fileName: fileName,\n                // 디버깅용으로 몇 번째 줄인지 표시 (나중에 빼도 됨)\n                lineIndex: i \n            }\n        });\n    }\n  }\n});\n\nreturn result;"
      },
