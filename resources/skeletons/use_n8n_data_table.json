    },
    {
      "parameters": {
        "operation": "get",
        "dataTableId": {
          "__rl": true,
          "value": "hay0AtNjwxmHjFVJ",
          "mode": "list",
          "cachedResultName": "embeddings",
          "cachedResultUrl": "/projects/rUzZX2dYKswL43yd/datatables/hay0AtNjwxmHjFVJ"
        },
        "returnAll": true
      },
      "type": "n8n-nodes-base.dataTable",
      "typeVersion": 1.1,
      "position": [
        512,
        1248
      ],
      "id": "41e607f2-9745-4b25-960e-5cdbce98c0a0",
      "name": "GetData"
    },
    {
      "parameters": {
        "jsCode": "// 질문 벡터\nconst queryVector = $('searchEmbedding').first().json.embedding.values\n\n// 전체 데이터\nconst allData = $('GetData').all()\n\n// 질문 텍스트\nconst queryText = $('chatMessage').first().json.chatInput || \"\";\n\n// 유사도 커트라인\nconst THRESHOLD = 0.6;\n\n// 유사도 계산\nconst cosineSimilarity = (vecA, vecB) =>{\n  let dotProduct = 0;\n  let normA = 0;\n  let normB = 0;\n  for (let i = 0; i < vecA.length; i++) {\n    dotProduct += vecA[i] * vecB[i];\n    normA += vecA[i] * vecA[i];\n    normB += vecB[i] * vecB[i];\n  }\n  if (normA === 0 || normB === 0) return 0;\n  \n  return dotProduct / (Math.sqrt(normA) * Math.sqrt(normB));\n}\n\n// 2자씩 잘라서 배열에 저장\nconst getNgrams = (text) => {\n    const cleanText = text.replace(/[^\\wㄱ-ㅎ가-힣]/g, '');\n    const grams = [];\n    for (let i = 0; i <= cleanText.length - 2; i++) {\n        grams.push(cleanText.substring(i, i + 2));\n    }\n    return [...new Set(grams)]; // 중복 제거\n};\n\nconst queryKeywords = queryText.split(/\\s+/).filter(w => w.length >= 2);\nconst queryGrams = getNgrams(queryText);\n\n// 유사도 점수 매기기\nconst rankedDocs = allData.map(item => {\n  let docVector = null\n  \n  try {\n    // 데이터 저장 할 때 embedding 처리해서 String으로 넣어뒀음.\n      docVector = typeof item.json.embedding === 'string' ? JSON.parse(item.json.embedding) : null;\n    \n  } catch (e) {\n      docVector = []; // 에러 방지용 빈 배열\n  }\n\n  const content = item.json.content || \"\";\n  const fileName = item.json.fileName || \"unknown\";\n  \n  if (!docVector || docVector.length === 0) {\n      return { content, fileName, score: 0 };\n  }\n\n  // 기본 유사도 점수\n  let score = cosineSimilarity(queryVector, docVector); \n\n  // 질문 키워드가 내용에 있으면 가산점 부여\n  queryKeywords.forEach(word => {\n        if (content.includes(word)) score += 0.1;\n  });\n\n  let gramMatchCount = 0;\n\n  // 질문 키워드에 단어가 내용에 있으면 가산점 부여\n  queryGrams.forEach(gram => {\n      if (content.includes(gram)) gramMatchCount++;\n  });\n\n  // 겹치는 2글자당 0.02점 가산\n  score += (gramMatchCount * 0.02);\n  \n  return { content, fileName, score };\n});\n\n// 유사도 순 정렬 (가중치 적용 후 점수 기준)\nrankedDocs.sort((a, b) => b.score - a.score);\n\n// 커트라인 밑으로는 버림\nconst validResults = rankedDocs.filter(doc => doc.score > THRESHOLD);\n\nconst getCount = validResults.length > 10 ? 10 : validResults.length\n\n// llm에서 최적 답변을 위해 최대 10개 리턴\nconst topResults = validResults.slice(0, getCount); \n\n// agent는 리턴 개수만큼 답변을 함으로 content에 담아 1개의 item을 리턴해야함.\nreturn [{\n    json: {\n        content: topResults \n    }\n}];"
      },
