    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key=AIzaSyAS26HQAYv7DL_kEbgzZAnKwMy_IsKXCRI",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"models/gemini-embedding-001\",\n  \"content\": {\n    \"parts\": [{\n      \"text\": {{ JSON.stringify($('chatMessage').first().json.chatInput) }}\n    }]\n  },\n  \"taskType\": \"RETRIEVAL_QUERY\"\n}",
        "options": {}
